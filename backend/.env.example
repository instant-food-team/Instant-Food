# Instant Food backend environment example
# Copy this file to `.env` and fill in real values locally.
#
# IMPORTANT:
# - For the current Python backend stack (`supabase==2.3.4`), use Supabase
#   legacy JWT keys for ANON and SERVICE_ROLE.
# - Do NOT paste `sb_publishable_...` or `sb_secret_...` keys here unless the
#   backend SDK has been upgraded and verified to support them.
# - Never expose SERVICE_ROLE or AI keys to the frontend.

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_legacy_anon_jwt_here
SUPABASE_SERVICE_ROLE_KEY=your_legacy_service_role_jwt_here

# AI provider
GEMINI_API_KEY=your_gemini_api_key_here

# AI model settings
AI_MODEL=gemini-2.5-flash
VISION_MODEL=gemini-2.5-flash
IMAGE_MODEL=gemini-2.5-flash-image
MAX_TOKENS=4096
TEMPERATURE=0.7

# App settings
APP_ENV=development
LOG_LEVEL=INFO
DEBUG=true

# API settings
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,https://frontend-flame-one-rgedpp5pu4.vercel.app

# Image settings
MAX_IMAGE_SIZE_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# Storage settings
USE_SUPABASE_STORAGE=true
STORAGE_BUCKET=instant-food
